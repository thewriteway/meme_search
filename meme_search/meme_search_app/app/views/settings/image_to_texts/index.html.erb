<div class="w-full px-4 py-8">
  <%= render "settings/shared/tabs" %>

  <div class="mb-8 mt-6">
    <h1 class="text-4xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent dark:from-indigo-400 dark:to-purple-400">
      AI Models
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mt-2">Select the vision-language provider and model for image description generation</p>
  </div>

  <% content_for :title, "Image to text models" %>

  <% active_tab = @provider_tab == "openai" ? "openai" : "local" %>
  <% provider_tab_panel_classes = "p-5 transition-all" %>
  <% provider_tab_button_classes = "text-lg font-bold text-gray-800 dark:text-white text-left" %>
  <% inactive_tab_classes = "bg-gray-100/70 dark:bg-slate-700/40 hover:bg-white/70 dark:hover:bg-slate-700/70" %>
  <% active_tab_classes = "bg-white dark:bg-slate-800 shadow-inner border-b-4 border-indigo-500" %>

  <div class="bg-white/90 dark:bg-slate-800/90 backdrop-blur-xl border border-white/20 dark:border-white/10 rounded-2xl shadow-lg overflow-hidden">
    <div class="grid grid-cols-1 sm:grid-cols-2 border-b border-gray-200 dark:border-gray-700">
      <div class="<%= provider_tab_panel_classes %> <%= active_tab == "local" ? active_tab_classes : inactive_tab_classes %>">
        <div class="flex flex-wrap items-center gap-3">
          <%= button_to "Local generator",
            settings_image_to_texts_path,
            method: :get,
            params: { provider_tab: "local" },
            form_class: "contents",
            class: provider_tab_button_classes %>
          <% if @provider_configuration.provider == "local" %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-700">Active</span>
          <% end %>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Runs through the bundled image-to-text service.</p>
      </div>

      <div class="<%= provider_tab_panel_classes %> <%= active_tab == "openai" ? active_tab_classes : inactive_tab_classes %>">
        <div class="flex flex-wrap items-center gap-3">
          <%= button_to "OpenAI-compatible API",
            settings_image_to_texts_path,
            method: :get,
            params: { provider_tab: "openai" },
            form_class: "contents",
            class: provider_tab_button_classes %>
          <% if @provider_configuration.provider == "openai" %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-700">Active</span>
          <% end %>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Runs through an external cloud vision model.</p>
      </div>
    </div>

    <% if active_tab == "local" %>
      <div class="p-6 space-y-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Local model</h2>
          <p class="text-gray-600 dark:text-gray-400 mt-1">Choose one local model. This is the default path for Meme Search.</p>
        </div>

        <%= form_with url: update_current_settings_image_to_texts_path, method: :post, id: "current-form", class: "space-y-6" do %>
          <div id="image_to_texts" class="grid grid-cols-1 gap-4">
            <% @image_to_texts.each do |image_to_text| %>
              <div class="bg-white/90 dark:bg-slate-800/90 backdrop-blur-xl border border-white/20 dark:border-white/10 rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all <%= "ring-2 ring-indigo-500 ring-offset-2 dark:ring-offset-slate-900" if image_to_text.current %>">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center space-x-3 mb-2">
                      <h3 class="text-xl font-bold text-gray-800 dark:text-white"><%= image_to_text.name %></h3>
                      <% if image_to_text.current %>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-700">
                          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                          </svg>
                          Active
                        </span>
                      <% end %>
                    </div>

                    <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-3">
                      <%= image_to_text.description %>
                    </p>

                    <a href="<%= image_to_text.resource %>" target="_blank"
                       class="inline-flex items-center text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium transition-colors">
                      Learn more
                      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </a>
                  </div>

                  <div data-controller="toggle" class="flex-shrink-0 sm:pl-6">
                    <input type="radio" class="hidden peer sr-only opacity-0"
                           id="image_to_text_<%= image_to_text.id %>"
                           value="<%= image_to_text.id %>"
                           name="current_id"
                           <%= "checked" if image_to_text.current %>
                           data-action="change->toggle#toggle">
                    <label class="relative flex h-8 w-14 cursor-pointer items-center rounded-full bg-gray-300 dark:bg-gray-600 px-0.5 outline-gray-400 transition-colors before:h-7 before:w-7 before:rounded-full before:bg-white before:shadow-md before:transition-transform before:duration-300 peer-checked:bg-indigo-500 peer-checked:before:translate-x-6 peer-focus-visible:outline peer-focus-visible:outline-offset-2 peer-focus-visible:outline-gray-400 peer-checked:peer-focus-visible:outline-indigo-500 hover:shadow-lg"
                           for="image_to_text_<%= image_to_text.id %>">
                      <span class="sr-only">Select <%= image_to_text.name %></span>
                    </label>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <div class="flex justify-center pt-4">
            <button type="submit" class="<%= submit_button_classes %> w-full sm:w-auto">
              Save Local Selection
            </button>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-6 space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
          <div>
            <h2 class="text-2xl font-bold text-gray-800 dark:text-white">OpenAI-compatible provider</h2>
            <p class="text-gray-600 dark:text-gray-400 mt-1">Choose a fixed cloud model and configure the key source.</p>
          </div>

          <% if @provider_configuration.openai_env_key? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-800 border border-amber-200">Env key detected</span>
          <% elsif @provider_setting.saved_openai_api_key? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700 border border-green-200">Saved key ready</span>
          <% else %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700 border border-red-200">Key missing</span>
          <% end %>
        </div>

        <%= form_with model: @provider_setting, url: save_openai_settings_settings_image_to_texts_path, method: :post, class: "space-y-5" do |form| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <%= form.label :openai_base_url, "Base URL", class: "block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2" %>
              <%= form.text_field :openai_base_url, class: "w-full rounded-xl border border-gray-300 dark:border-gray-600 bg-white/90 dark:bg-slate-700/90 px-4 py-3 text-gray-900 dark:text-white" %>
              <% if @provider_configuration.openai_base_url_env_override? %>
                <p class="text-sm text-amber-700 dark:text-amber-300 mt-2">OPENAI_API_BASE_URL is overriding this saved value at runtime.</p>
              <% end %>
            </div>

            <div>
              <%= form.label :openai_model, "Cloud model", class: "block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2" %>
              <%= form.select :openai_model, DescriptionProviderSetting.openai_model_options, {}, class: "w-full rounded-xl border border-gray-300 dark:border-gray-600 bg-white/90 dark:bg-slate-700/90 px-4 py-3 text-gray-900 dark:text-white" %>
              <% if @provider_configuration.openai_model_env_override? %>
                <p class="text-sm text-amber-700 dark:text-amber-300 mt-2">OPENAI_VISION_MODEL is overriding this saved value at runtime.</p>
              <% end %>
            </div>
          </div>

          <div>
            <%= form.label :openai_api_key, "API key", class: "block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2" %>
            <%= form.password_field :openai_api_key, value: nil, placeholder: "Paste a new key to replace the saved key", class: "w-full rounded-xl border border-gray-300 dark:border-gray-600 bg-white/90 dark:bg-slate-700/90 px-4 py-3 text-gray-900 dark:text-white" %>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">The full saved key is never shown again. If OPENAI_API_KEY is set, it takes precedence at runtime.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-3 p-4 rounded-2xl bg-gray-50 dark:bg-slate-900/60 border border-gray-200 dark:border-gray-700">
            <div>
              <div class="text-xs uppercase tracking-wide font-bold text-gray-500 dark:text-gray-400">Runtime key</div>
              <div class="font-bold text-gray-800 dark:text-white mt-1"><%= @provider_configuration.openai_runtime_key_source %></div>
            </div>

            <div>
              <div class="text-xs uppercase tracking-wide font-bold text-gray-500 dark:text-gray-400">Saved key</div>
              <div class="font-bold text-gray-800 dark:text-white mt-1"><%= @provider_setting.redacted_openai_api_key %></div>
            </div>

            <div>
              <div class="text-xs uppercase tracking-wide font-bold text-gray-500 dark:text-gray-400">Last test</div>
              <div class="font-bold text-gray-800 dark:text-white mt-1"><%= @provider_setting.openai_last_test_status.humanize %></div>
              <% if @provider_setting.openai_last_tested_at.present? %>
                <div class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= time_ago_in_words(@provider_setting.openai_last_tested_at) %> ago</div>
              <% end %>
            </div>
          </div>

          <% if @provider_setting.openai_last_test_error.present? %>
            <div class="p-4 rounded-2xl bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-800 text-sm text-red-700 dark:text-red-300">
              <%= @provider_setting.openai_last_test_error %>
            </div>
          <% end %>

          <div class="flex flex-col sm:flex-row justify-end gap-3">
            <%= form.submit "Save Cloud Selection", class: submit_button_classes %>
          </div>
        <% end %>

        <div class="flex flex-col sm:flex-row justify-end gap-3">
          <%= button_to "Test connection", test_openai_settings_settings_image_to_texts_path, method: :post, class: rescan_button_classes %>
          <%= button_to "Clear saved key", clear_openai_key_settings_image_to_texts_path, method: :delete, class: delete_button_classes %>
        </div>
      </div>
    <% end %>
  </div>
</div>
