# Keep root-context Rails image builds small and free of local secrets.
**

!VERSION
!meme_search/
!meme_search/meme_search_app/
!meme_search/meme_search_app/**

meme_search/db_data/
meme_search/direct-uploads/
meme_search/image_to_text_generator/
meme_search/memes/
meme_search/models/

meme_search/meme_search_app/.env*
!meme_search/meme_search_app/.env*.erb
meme_search/meme_search_app/.bundle
meme_search/meme_search_app/config/master.key
meme_search/meme_search_app/config/credentials/*.key
meme_search/meme_search_app/log/*
!meme_search/meme_search_app/log/.keep
meme_search/meme_search_app/tmp/*
!meme_search/meme_search_app/tmp/.keep
meme_search/meme_search_app/tmp/pids/*
!meme_search/meme_search_app/tmp/pids/.keep
meme_search/meme_search_app/storage/*
!meme_search/meme_search_app/storage/.keep
meme_search/meme_search_app/tmp/storage/*
!meme_search/meme_search_app/tmp/storage/.keep
meme_search/meme_search_app/node_modules/
meme_search/meme_search_app/app/assets/builds/*
!meme_search/meme_search_app/app/assets/builds/.keep
meme_search/meme_search_app/public/assets
